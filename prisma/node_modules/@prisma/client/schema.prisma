generator client {
  provider = "prisma-client-js"
  output   = "./node_modules/@prisma/client" // esse output é opcional, mas recomendado
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Necessidade {
  id         Int    @id @default(autoincrement())
  nome       String
  item       String
  quantidade Int
  contato    Int
}
